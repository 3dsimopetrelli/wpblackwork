<?xml version="1.0"?>
<ruleset name="Blackwork PHPCS">
    <description>
        WordPress coding standards with a temporary legacy baseline exclude for the historic root bootstrap file.
    </description>

    <rule ref="WordPress" />

    <file>admin</file>
    <file>includes</file>
    <file>metabox</file>
    <file>templates</file>
    <file>woocommerce</file>
    <file>cart-popup</file>
    <file>BW_coming_soon</file>

    <!--
      Temporary baseline strategy:
      - legacy violations in blackwork-core-plugin.php are tracked via composer script lint:legacy
      - all other PHP files are fully enforced by lint/lint:main
    -->
    <exclude-pattern>*/blackwork-core-plugin.php</exclude-pattern>
    <exclude-pattern>*/vendor/*</exclude-pattern>

    <arg name="extensions" value="php" />
</ruleset>
