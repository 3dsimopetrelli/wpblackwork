{
    "name": "blackwork/wpblackwork",
    "description": "BlackWork custom plugin",
    "type": "wordpress-plugin",
    "require-dev": {
        "squizlabs/php_codesniffer": "^3",
        "wp-coding-standards/wpcs": "^3",
        "phpcompatibility/phpcompatibility-wp": "^2",
        "dealerdirect/phpcodesniffer-composer-installer": "^1"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "scripts": {
        "lint": "phpcs -d memory_limit=512M --standard=phpcs.xml.dist blackwork-core-plugin.php",
        "lint:main": "phpcs -d memory_limit=512M --standard=phpcs.xml.dist blackwork-core-plugin.php",
        "lint:legacy": "phpcs -d memory_limit=512M --standard=WordPress blackwork-core-plugin.php",
        "lint:fix:legacy": "phpcbf -d memory_limit=512M --standard=WordPress blackwork-core-plugin.php",
        "lint:strict": "phpcs -d memory_limit=512M --standard=WordPress admin includes metabox templates woocommerce cart-popup BW_coming_soon",
        "lint:changed": "sh -c 'FILES=$(git diff --name-only --diff-filter=ACMRTUXB HEAD -- \"*.php\"); if [ -z \"$FILES\" ]; then echo \"No changed PHP files to lint.\"; else phpcs -d memory_limit=512M --standard=phpcs.xml.dist $FILES; fi'"
    }
}
